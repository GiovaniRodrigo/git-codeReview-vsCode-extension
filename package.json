{
  "name": "git-code-review",
  "displayName": "Code Review Design Extension",
  "description": "Professional VS Code extension for architectural code review, PR analysis, and engineering telemetry with Material Design 3.",
  "version": "1.0.4",
  "publisher": "CodeReviewExtension",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GiovaniRodrigo/git-codeReview-vsCode-extension"
  },
  "homepage": "https://github.com/GiovaniRodrigo/git-codeReview-vsCode-extension/#readme",
  "bugs": {
    "url": "https://github.com/GiovaniRodrigo/git-codeReview-vsCode-extension/issues"
  },
  "icon": "media/logo_128px.png",
  "keywords": [
    "code-review",
    "architecture",
    "clean-architecture",
    "solid",
    "telemetry",
    "git"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onCommand:codeReview.openDashboard",
    "onCommand:codeReview.startReview",
    "onCommand:codeReview.openPullRequest",
    "onView:codeReview.sidebar",
    "onCommand:codeReview.exportAuditLog",
    "onCommand:codeReview.exportLocalDatabase",
    "onCommand:codeReview.createBackup",
    "onCommand:codeReview.syncRemote"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeReview.openDashboard",
        "title": "Code Review: Abrir Dashboard"
      },
      {
        "command": "codeReview.startReview",
        "title": "Code Review: Iniciar Revisão"
      },
      {
        "command": "codeReview.openPullRequest",
        "title": "Code Review: Abrir Pull Request"
      },
      {
        "command": "codeReview.exportAuditLog",
        "title": "Code Review: Exportar Auditoria"
      },
      {
        "command": "codeReview.exportLocalDatabase",
        "title": "Code Review: Exportar Banco Local"
      },
      {
        "command": "codeReview.createBackup",
        "title": "Code Review: Criar Backup"
      },
      {
        "command": "codeReview.syncRemote",
        "title": "Code Review: Sincronizar Remoto"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeReview",
          "title": "Code Review",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeReview": [
        {
          "id": "codeReview.sidebar",
          "name": "Resumo"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codeReview.openDashboard",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      },
      {
        "command": "codeReview.startReview",
        "key": "ctrl+alt+shift+r",
        "mac": "cmd+alt+shift+r"
      },
      {
        "command": "codeReview.exportAuditLog",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e"
      },
      {
        "command": "codeReview.exportLocalDatabase",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d"
      },
      {
        "command": "codeReview.createBackup",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b"
      },
      {
        "command": "codeReview.syncRemote",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      }
    ],
    "configuration": {
      "title": "Code Review",
      "properties": {
        "codeReview.remoteSyncPath": {
          "type": "string",
          "default": "",
          "description": "Caminho opcional para sincronizacao remota simulada da base local de code review."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run build:webview && npm run build:extension",
    "build": "npm run compile",
    "build:extension": "node esbuild.mjs",
    "build:webview": "npm ci --prefix webview-ui && npm --prefix webview-ui run build",
    "ci:install": "npm ci && npm ci --prefix webview-ui",
    "validate:production": "npm run ci:install && npm test && npm run build:extension && npm run build:webview && npm audit --omit=dev && npm --prefix webview-ui audit --omit=dev && npm run package",
    "watch": "npm run watch:extension",
    "watch:extension": "node esbuild.mjs --watch",
    "watch:webview": "npm --prefix webview-ui run build -- --watch",
    "test": "node --test test/*.test.mjs",
    "package": "npm run compile && npx @vscode/vsce package --no-dependencies --allow-missing-repository",
    "clean": "rm -rf dist webview-ui/dist node_modules webview-ui/node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.5"
  }
}
