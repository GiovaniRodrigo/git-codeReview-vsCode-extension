{
  "name": "git-code-review",
  "displayName": "Git Code Review Local",
  "description": "Navigate local Git branches, tags, commits, changed files, and diffs from VS Code.",
  "version": "0.0.1",
  "publisher": "CodeReviewExtension",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/GiovaniRodrigo/git-codeReview-vsCode-extension.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onView:codeReviewExplorer",
    "onCommand:codeReview.refresh",
    "onCommand:codeReview.fetchRemoteBranches",
    "onCommand:codeReview.openReview",
    "onCommand:codeReview.createReviewProcess",
    "onCommand:codeReview.resumeReviewProcess",
    "onCommand:codeReview.completeReviewProcess",
    "onCommand:codeReview.signInGitHub",
    "onCommand:codeReview.linkGitLab",
    "onCommand:codeReview.openPullRequest",
    "onCommand:codeReview.openMergeRequest",
    "onCommand:codeReview.approvePullRequest",
    "onCommand:codeReview.requestChanges",
    "onCommand:codeReview.commentPullRequest",
    "onCommand:codeReview.approveMergeRequest",
    "onCommand:codeReview.rejectMergeRequest",
    "onCommand:codeReview.commentMergeRequest",
    "onCommand:codeReview.openCommitDetails",
    "onCommand:codeReview.openFileDiff",
    "onCommand:codeReview.openGithubStyleDiff",
    "onCommand:codeReview.addReviewComment",
    "onCommand:codeReview.compareBranches",
    "onCommand:codeReview.markReviewed",
    "onCommand:codeReview.showUnreviewed"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "configuration": {
      "title": "Code Review",
      "properties": {
        "codeReview.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable optional telemetry. Telemetry is disabled by default and only sends events when an endpoint is configured."
        },
        "codeReview.telemetry.endpoint": {
          "type": "string",
          "default": "",
          "description": "HTTPS endpoint that receives optional telemetry POST requests. Leave empty to disable telemetry sending."
        },
        "codeReview.gitlab.customDomains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom GitLab hostnames for self-hosted instances (e.g. git.company.com)."
        },
        "codeReview.ai.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI features (summaries, suggestions). AI is disabled by default."
        },
        "codeReview.ai.provider": {
          "type": "string",
          "default": "mock",
          "enum": [
            "mock"
          ],
          "description": "AI provider to use for analysis."
        }
      }
    },
    "views": {
      "scm": [
        {
          "id": "codeReviewExplorer",
          "name": "Git Review"
        }
      ]
    },
    "commands": [
      {
        "command": "codeReview.refresh",
        "title": "Code Review: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codeReview.fetchRemoteBranches",
        "title": "Code Review: Fetch Remote Branches",
        "icon": "$(cloud-download)"
      },
      {
        "command": "codeReview.openReview",
        "title": "Code Review: Open Review"
      },
      {
        "command": "codeReview.createReviewProcess",
        "title": "Code Review: Create Review Process",
        "icon": "$(bookmark)"
      },
      {
        "command": "codeReview.resumeReviewProcess",
        "title": "Code Review: Resume Review Process",
        "icon": "$(history)"
      },
      {
        "command": "codeReview.completeReviewProcess",
        "title": "Code Review: Complete Review Process",
        "icon": "$(pass)"
      },
      {
        "command": "codeReview.signInGitHub",
        "title": "Code Review: Sign In to GitHub",
        "icon": "$(github-inverted)"
      },
      {
        "command": "codeReview.linkGitLab",
        "title": "Code Review: Link GitLab",
        "icon": "$(gitlab)"
      },
      {
        "command": "codeReview.openPullRequest",
        "title": "Code Review: Open Pull Request"
      },
      {
        "command": "codeReview.openMergeRequest",
        "title": "Code Review: Open Merge Request"
      },
      {
        "command": "codeReview.approvePullRequest",
        "title": "Code Review: Approve Pull Request"
      },
      {
        "command": "codeReview.requestChanges",
        "title": "Code Review: Request Changes"
      },
      {
        "command": "codeReview.commentPullRequest",
        "title": "Code Review: Comment Pull Request"
      },
      {
        "command": "codeReview.approveMergeRequest",
        "title": "Code Review: Approve Merge Request"
      },
      {
        "command": "codeReview.rejectMergeRequest",
        "title": "Code Review: Request Changes (Unapprove)"
      },
      {
        "command": "codeReview.commentMergeRequest",
        "title": "Code Review: Comment Merge Request"
      },
      {
        "command": "codeReview.openCommitDetails",
        "title": "Code Review: Open Commit Details"
      },
      {
        "command": "codeReview.openFileDiff",
        "title": "Code Review: Open File Diff"
      },
      {
        "command": "codeReview.openGithubStyleDiff",
        "title": "Code Review: Open GitHub Style Diff"
      },
      {
        "command": "codeReview.addReviewComment",
        "title": "Code Review: Add Review Comment"
      },
      {
        "command": "codeReview.compareBranches",
        "title": "Code Review: Compare Branches",
        "icon": "$(git-compare)"
      },
      {
        "command": "codeReview.markReviewed",
        "title": "Code Review: Mark Commit Reviewed"
      },
      {
        "command": "codeReview.showUnreviewed",
        "title": "Code Review: Show Unreviewed Commits",
        "icon": "$(checklist)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codeReview.refresh",
          "when": "view == codeReviewExplorer",
          "group": "navigation"
        },
        {
          "command": "codeReview.fetchRemoteBranches",
          "when": "view == codeReviewExplorer",
          "group": "navigation"
        },
        {
          "command": "codeReview.compareBranches",
          "when": "view == codeReviewExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "codeReview.fetchRemoteBranches",
          "when": "view == codeReviewExplorer && viewItem == remoteRefGroup",
          "group": "inline"
        },
        {
          "command": "codeReview.openReview",
          "when": "view == codeReviewExplorer && viewItem =~ /reviewable/",
          "group": "inline"
        },
        {
          "command": "codeReview.createReviewProcess",
          "when": "view == codeReviewExplorer && viewItem =~ /reviewable/",
          "group": "inline"
        },
        {
          "command": "codeReview.openCommitDetails",
          "when": "view == codeReviewExplorer && viewItem == commit",
          "group": "inline"
        },
        {
          "command": "codeReview.markReviewed",
          "when": "view == codeReviewExplorer && viewItem == commit",
          "group": "inline"
        },
        {
          "command": "codeReview.openFileDiff",
          "when": "view == codeReviewExplorer && viewItem == file",
          "group": "inline"
        },
        {
          "command": "codeReview.openGithubStyleDiff",
          "when": "view == codeReviewExplorer && viewItem == file",
          "group": "inline"
        },
        {
          "command": "codeReview.addReviewComment",
          "when": "view == codeReviewExplorer && viewItem == file",
          "group": "inline"
        },
        {
          "command": "codeReview.approvePullRequest",
          "when": "view == codeReviewExplorer && viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "codeReview.requestChanges",
          "when": "view == codeReviewExplorer && viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "codeReview.commentPullRequest",
          "when": "view == codeReviewExplorer && viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "codeReview.approveMergeRequest",
          "when": "view == codeReviewExplorer && viewItem == mergeRequest",
          "group": "inline"
        },
        {
          "command": "codeReview.rejectMergeRequest",
          "when": "view == codeReviewExplorer && viewItem == mergeRequest",
          "group": "inline"
        },
        {
          "command": "codeReview.commentMergeRequest",
          "when": "view == codeReviewExplorer && viewItem == mergeRequest",
          "group": "inline"
        },
        {
          "command": "codeReview.openMergeRequest",
          "when": "view == codeReviewExplorer && viewItem == mergeRequest",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codeReview.refresh",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "view == codeReviewExplorer"
      },
      {
        "command": "codeReview.compareBranches",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      },
      {
        "command": "codeReview.runComplianceValidation",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v"
      },
      {
        "command": "codeReview.applyArchitectureCorrection",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "codeReview.showTelemetryHistory",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      },
      {
        "command": "codeReview.runAiReview",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test \"out/test/**/*.test.js\"",
    "package": "vsce package --allow-missing-repository",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1"
  }
}